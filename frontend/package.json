    "axios-mock-adapter": "^2.1.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.23",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "notistack": "^3.0.2",
    "p5": "^2.2.0",
    "perfect-scrollbar": "^1.5.6",
    "react": "^19.2.0",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
